# Copy this file to .env and fill in the values
# NEVER commit the actual .env file to GitHub

# Required: A long random string used to sign JWT tokens
# Generate one at: https://randomkeygen.com/ (use "Fort Knox Passwords")
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# Optional: Port the server runs on (default: 5000)
PORT=5000

# Required for production: Your frontend URL (e.g. https://rrdch.org or your Vercel URL)
# This prevents unauthorized cross-origin requests to your API
ALLOWED_ORIGIN=https://www.rrdch.org
